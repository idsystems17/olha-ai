# Supabase (pegar em Project Settings > API do projeto reaproveitado)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NUNCA prefixar com NEXT_PUBLIC_ — só usada em rotas server-side (ver SEGURANCA.md)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Kiwify
# Token gerado ao criar o webhook no painel da Kiwify (Apps > Webhooks).
KIWIFY_WEBHOOK_SECRET=
# Link de checkout do produto de assinatura (não é segredo, pode ir no bundle do cliente).
NEXT_PUBLIC_KIWIFY_CHECKOUT_URL=

# Suporte (chat com IA no painel)
ANTHROPIC_API_KEY=
# WhatsApp da Izis pra onde o chat escala quando não resolve. Só dígitos, com DDI 55.
SUPORTE_WHATSAPP=

# Segredo pra "temperar" o hash do CPF (nunca commitar o valor real).
# Gerar uma vez com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CPF_HASH_PEPPER=
